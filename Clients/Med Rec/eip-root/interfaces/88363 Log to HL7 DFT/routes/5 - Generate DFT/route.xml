<?xml version="1.0" encoding="UTF-8"?>
<Route xmlns="http://www.pilotfishtechnology.com/eipr/RouteSpec" CreatedBy="bthannan@pilotfishtechnology.com" RouteSpecificPooling="true" debugTraceCurrentSecondsToKeepFiles="-1" debugTraceMaxFiles="-1" debuggingTrace="false" debuggingTraceExpression="" debuggingTracePath="" transactionTimeToLive="300000">
  <RouteMetadata />
  <RoutingModule class="com.pilotfish.eip.modules.internal.NullRoutingModule" />
  <TransactionMonitors>
    <TransactionMonitor class="com.pilotfish.eip.modules.internal.RouteTriggerMonitor" name="88363 Log to HL7 DFT.3 - Generate DFT.Transaction Monitor">
      <ModuleConfig>
        <ErrorListenerName>88363 Log to HL7 DFT.99 - Error Handling.Programmable (Trigger) Listener</ErrorListenerName>
        <IncludeData>true</IncludeData>
        <IncludeAttributes>true</IncludeAttributes>
        <SetDataAsMessage>false</SetDataAsMessage>
        <ExceptionClassName />
        <ExceptionMessageLevel>-1</ExceptionMessageLevel>
        <MustContainString />
        <MustNotContainString />
        <IncludeStages />
      </ModuleConfig>
    </TransactionMonitor>
  </TransactionMonitors>
  <Source icon="" name="System Unnamed">
    <FormatProfile name="Relay (System Format)" />
    <SourceMetadata />
    <Listener class="com.pilotfish.eip.modules.core.TriggerableListener" enabled="true" name="88363 Log to HL7 DFT.3 - Generate DFT.Programmable (Trigger) Listener">
      <ModuleConfig>
        <IS_TRIGGERABLE_LISTENER>false</IS_TRIGGERABLE_LISTENER>
        <CLIAllowed>false</CLIAllowed>
        <RESTART_ON_ERROR_TAG>false</RESTART_ON_ERROR_TAG>
        <FIFOQueueName />
        <FIFOQueueDelay>500</FIFOQueueDelay>
        <TransactionLoggingAllowed>false</TransactionLoggingAllowed>
        <TransactionLoggingStoreData>false</TransactionLoggingStoreData>
        <TransactionLoggingStoreDataBase64>false</TransactionLoggingStoreDataBase64>
        <TransactionLoggingStoreAttributes>false</TransactionLoggingStoreAttributes>
        <TransactionLoggingLogAllAttributes>false</TransactionLoggingLogAllAttributes>
        <TransactionLoggingAllowedLoggedAttributes>[eip_pair:Transaction Resubmit Attribute:eip_name:com.pilotfish.Dashboard.ResubmissionOriginalTxID:eip_value]</TransactionLoggingAllowedLoggedAttributes>
        <CheckInactivity>false</CheckInactivity>
        <InactivityTransactionCount>1</InactivityTransactionCount>
        <InactivityPolling>500</InactivityPolling>
        <MonitoringTime>11:33-11:33</MonitoringTime>
        <InactivityExcludedDays />
        <InactivityIncludeErrors>false</InactivityIncludeErrors>
        <ThrottlingMode>None</ThrottlingMode>
        <ThrottlingMechanism>Blocking</ThrottlingMechanism>
        <ThrottlingConcurrentMessages>1</ThrottlingConcurrentMessages>
        <ThrottlingTimedInterval>1</ThrottlingTimedInterval>
        <ThrottlingSynchronousTimeout>60</ThrottlingSynchronousTimeout>
        <CallingRoutes />
      </ModuleConfig>
    </Listener>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.other.RegExProcessor" name="88363 Log to HL7 DFT.5 - Generate DFT.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <UseDefaultEncoding>false</UseDefaultEncoding>
          <Encoding>UTF-8</Encoding>
          <REGEX_TABLE_TAG>[eip_pair:Split:eip_name:XCSData:eip_value]</REGEX_TABLE_TAG>
          <PostProcessOptions>Replace all \n with newlines</PostProcessOptions>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Source>
  <Target icon="" name="System Unnamed">
    <FormatProfile name="Generate DFT" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.file.DirectoryTransport" name="88363 Log to HL7 DFT.3 - Generate DFT.Directory / File Transport" retries="1">
      <ModuleConfig>
        <TargetDirectory>$$HL7_TARGET_DIRECTORY</TargetDirectory>
        <FileName>{ognl:( getAttribute('SplitShortName') != null &amp;&amp; getAttribute('SplitShortName') != '' ? getAttribute('SplitShortName') : getAttribute('Client') ) + new java.text.SimpleDateFormat('MMdd').format(new java.util.Date()) + 'd'}</FileName>
        <FileExtension>DFT</FileExtension>
        <UseFullFilePath>Disabled</UseFullFilePath>
        <FullPathToFile />
        <AppendToFile>Create New</AppendToFile>
        <MAXIMUM_MEMORY_SIZE>-1</MAXIMUM_MEMORY_SIZE>
        <FileNameConflictPattern />
        <BatchSensitive>false</BatchSensitive>
        <Command />
        <Shell>/bin/bash</Shell>
      </ModuleConfig>
    </Transport>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.file.EOLProcessor" name="Cleanup Empty Lines 1">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <EndlineSequence>\n</EndlineSequence>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.custom.EmptyLineProcessor" name="Cleanup Empty Lines 2">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
</Route>

