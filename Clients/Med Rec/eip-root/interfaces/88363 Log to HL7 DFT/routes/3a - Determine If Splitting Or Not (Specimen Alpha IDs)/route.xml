<?xml version="1.0" encoding="UTF-8"?>
<Route xmlns="http://www.pilotfishtechnology.com/eipr/RouteSpec" CreatedBy="bthannan@pilotfishtechnology.com" RouteSpecificPooling="true" debugTraceCurrentSecondsToKeepFiles="-1" debugTraceMaxFiles="-1" debuggingTrace="false" debuggingTraceExpression="" debuggingTracePath="" transactionTimeToLive="300000">
  <RouteMetadata />
  <RoutingModule class="com.pilotfish.eip.modules.routing.XPathRoutingModule">
    <ModuleConfig>
      <RuleSet accumulate="false">
        <Rule>
          <Targets>
            <TransportTarget name="Do Splits Route to Route Transport" />
          </Targets>
          <Condition>
            <OGNLExpression>getAttribute('is_splitting')</OGNLExpression>
          </Condition>
        </Rule>
        <Rule>
          <Targets>
            <TransportTarget name="No Splits Route to Route Transport" />
          </Targets>
          <Condition>
            <OGNLExpression>true</OGNLExpression>
          </Condition>
        </Rule>
      </RuleSet>
    </ModuleConfig>
  </RoutingModule>
  <TransactionMonitors>
    <TransactionMonitor class="com.pilotfish.eip.modules.internal.RouteTriggerMonitor" name="88363 Log to HL7 DFT.3 - Determine If Splitting Or Not.Transaction Monitor">
      <ModuleConfig>
        <ErrorListenerName>88363 Log to HL7 DFT.99 - Error Handling.Programmable (Trigger) Listener</ErrorListenerName>
        <IncludeData>true</IncludeData>
        <IncludeAttributes>true</IncludeAttributes>
        <SetDataAsMessage>false</SetDataAsMessage>
        <ExceptionClassName />
        <ExceptionMessageLevel>-1</ExceptionMessageLevel>
        <MustContainString />
        <MustNotContainString />
        <IncludeStages />
      </ModuleConfig>
    </TransactionMonitor>
  </TransactionMonitors>
  <Source icon="" name="System Unnamed">
    <FormatProfile name="Relay (System Format)" />
    <SourceMetadata />
    <Listener class="com.pilotfish.eip.modules.core.TriggerableListener" enabled="true" name="88363 Log to HL7 DFT.3 - Determine If Splitting Or Not.Programmable (Trigger) Listener">
      <ModuleConfig>
        <IS_TRIGGERABLE_LISTENER>false</IS_TRIGGERABLE_LISTENER>
        <CLIAllowed>false</CLIAllowed>
        <RESTART_ON_ERROR_TAG>false</RESTART_ON_ERROR_TAG>
        <FIFOQueueName />
        <FIFOQueueDelay>500</FIFOQueueDelay>
        <TransactionLoggingAllowed>false</TransactionLoggingAllowed>
        <TransactionLoggingStoreData>false</TransactionLoggingStoreData>
        <TransactionLoggingStoreDataBase64>false</TransactionLoggingStoreDataBase64>
        <TransactionLoggingStoreAttributes>false</TransactionLoggingStoreAttributes>
        <TransactionLoggingLogAllAttributes>false</TransactionLoggingLogAllAttributes>
        <TransactionLoggingAllowedLoggedAttributes>[eip_pair:Transaction Resubmit Attribute:eip_name:com.pilotfish.Dashboard.ResubmissionOriginalTxID:eip_value]</TransactionLoggingAllowedLoggedAttributes>
        <CheckInactivity>false</CheckInactivity>
        <InactivityTransactionCount>1</InactivityTransactionCount>
        <InactivityPolling>500</InactivityPolling>
        <MonitoringTime>12:23-12:23</MonitoringTime>
        <InactivityExcludedDays />
        <InactivityIncludeErrors>false</InactivityIncludeErrors>
        <ThrottlingMode>None</ThrottlingMode>
        <ThrottlingMechanism>Blocking</ThrottlingMechanism>
        <ThrottlingConcurrentMessages>1</ThrottlingConcurrentMessages>
        <ThrottlingTimedInterval>1</ThrottlingTimedInterval>
        <ThrottlingSynchronousTimeout>60</ThrottlingSynchronousTimeout>
        <CallingRoutes />
      </ModuleConfig>
    </Listener>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.internal.TransactionAttributePopulationProcessor" name="88363 Log to HL7 DFT.3 - Determine If Splitting Or Not.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributePairs>[eip_pair:is_splitting:eip_name:{ognl:getAttribute('facilityName') == 'SKY' || getAttribute('facilityName') == 'SKR' || getAttribute('facilityName') == 'SWO' ? true : false}:eip_value]</AttributePairs>
          <AttributeScope>Transaction</AttributeScope>
          <GlobalAttributes>BUCKET</GlobalAttributes>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Source>
  <Target icon="" name="Go To Spec Alpha Splitting">
    <FormatProfile name="Relay (System Format)" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.internal.EIPTransport" name="Do Splits Route to Route Transport" retries="1">
      <ModuleConfig>
        <ServiceName>88363 Log to HL7 DFT.2a - Split On Specimen Alpha IDs.Programmable (Trigger) Listener</ServiceName>
        <CallbackListenerName />
        <Timeout>60</Timeout>
      </ModuleConfig>
    </Transport>
  </Target>
  <Target icon="" name="No Spec Alpha Splitting, Onto Facility Splits">
    <FormatProfile name="Relay (System Format)" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.internal.EIPTransport" name="No Splits Route to Route Transport" retries="1">
      <ModuleConfig>
        <ServiceName>4 - Split and Strip Records by Facility.Programmable (Trigger) Listener</ServiceName>
        <CallbackListenerName />
        <Timeout>60</Timeout>
      </ModuleConfig>
    </Transport>
  </Target>
</Route>

