<?xml version="1.0" encoding="UTF-8"?>
<Route xmlns="http://www.pilotfishtechnology.com/eipr/RouteSpec" CreatedBy="bthannan@pilotfishtechnology.com" RouteSpecificPooling="true" debugTraceCurrentSecondsToKeepFiles="-1" debugTraceMaxFiles="-1" debuggingTrace="false" debuggingTraceExpression="" debuggingTracePath="" transactionTimeToLive="300000">
  <RouteMetadata />
  <RoutingModule class="com.pilotfish.eip.modules.internal.NullRoutingModule" />
  <TransactionMonitors>
    <TransactionMonitor class="com.pilotfish.eip.modules.internal.RouteTriggerMonitor" name="88363 Log to HL7 DFT.3 - Generate DFT.Transaction Monitor-Copy-1">
      <ModuleConfig>
        <ErrorListenerName>88363 Log to HL7 DFT.99 - Error Handling.Programmable (Trigger) Listener</ErrorListenerName>
        <IncludeData>true</IncludeData>
        <IncludeAttributes>true</IncludeAttributes>
        <SetDataAsMessage>false</SetDataAsMessage>
        <ExceptionClassName />
        <ExceptionMessageLevel>-1</ExceptionMessageLevel>
        <MustContainString />
        <MustNotContainString />
        <IncludeStages />
      </ModuleConfig>
    </TransactionMonitor>
  </TransactionMonitors>
  <Source icon="" name="System Unnamed">
    <FormatProfile name="CSV to XML" />
    <SourceMetadata />
    <Listener class="com.pilotfish.eip.modules.core.TriggerableListener" enabled="true" name="88363 Log to HL7 DFT.2 - Flat File to XML.Programmable (Trigger) Listener">
      <ModuleConfig>
        <IS_TRIGGERABLE_LISTENER>false</IS_TRIGGERABLE_LISTENER>
        <CLIAllowed>false</CLIAllowed>
        <RESTART_ON_ERROR_TAG>false</RESTART_ON_ERROR_TAG>
        <FIFOQueueName />
        <FIFOQueueDelay>500</FIFOQueueDelay>
        <TransactionLoggingAllowed>false</TransactionLoggingAllowed>
        <TransactionLoggingStoreData>false</TransactionLoggingStoreData>
        <TransactionLoggingStoreDataBase64>false</TransactionLoggingStoreDataBase64>
        <TransactionLoggingStoreAttributes>false</TransactionLoggingStoreAttributes>
        <TransactionLoggingLogAllAttributes>false</TransactionLoggingLogAllAttributes>
        <TransactionLoggingAllowedLoggedAttributes>[eip_pair:Transaction Resubmit Attribute:eip_name:com.pilotfish.Dashboard.ResubmissionOriginalTxID:eip_value]</TransactionLoggingAllowedLoggedAttributes>
        <CheckInactivity>false</CheckInactivity>
        <InactivityTransactionCount>1</InactivityTransactionCount>
        <InactivityPolling>500</InactivityPolling>
        <MonitoringTime>11:33-11:33</MonitoringTime>
        <InactivityExcludedDays />
        <InactivityIncludeErrors>false</InactivityIncludeErrors>
        <ThrottlingMode>None</ThrottlingMode>
        <ThrottlingMechanism>Blocking</ThrottlingMechanism>
        <ThrottlingConcurrentMessages>1</ThrottlingConcurrentMessages>
        <ThrottlingTimedInterval>1</ThrottlingTimedInterval>
        <ThrottlingSynchronousTimeout>60</ThrottlingSynchronousTimeout>
        <CallingRoutes />
      </ModuleConfig>
    </Listener>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.other.RegExProcessor" name="88363 Log to HL7 DFT.2 - Flat File to XML.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <UseDefaultEncoding>false</UseDefaultEncoding>
          <Encoding>UTF-8</Encoding>
          <REGEX_TABLE_TAG>[eip_pair:\"\s:eip_name:\^:eip_value][eip_pair:\":eip_name::eip_value]</REGEX_TABLE_TAG>
          <PostProcessOptions>Replace all \n with newlines</PostProcessOptions>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Source>
  <Target icon="" name="Next Route">
    <FormatProfile name="Relay (System Format)" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.internal.EIPTransport" name="88363 Log to HL7 DFT.2 - Flat File to XML.Route to Route Transport" retries="1">
      <ModuleConfig>
        <ServiceName>88363 Log to HL7 DFT.3 - Determine If Splitting Or Not.Programmable (Trigger) Listener</ServiceName>
        <CallbackListenerName />
        <Timeout>60</Timeout>
      </ModuleConfig>
    </Transport>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Performing Doctors Logic">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform-perf-drs.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Default Empty Performing Doctors to SU">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform-default-perf-drs-to-SU.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.other.XPathEvaluatorProcessor" name="Get SU Accounts Count">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeScope>Transaction</AttributeScope>
          <XPathExpressions>[eip_pair:SUAccountsCount:eip_name:count(//XCSRecord[PerformingDoctors = 'SU']):eip_value]</XPathExpressions>
          <GlobalAttributeExpressions />
          <Namespaces>null</Namespaces>
          <Namespace />
          <XPath1Compatibility>false</XPath1Compatibility>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.CallRouteProcessor" name="Call Route to Generate SU Kickout Report">
        <ModuleConfig>
          <ExecuteProcessor>{ognl:getAttribute('SUAccountsCount') != 0}</ExecuteProcessor>
          <Listener>88363 Log to HL7 DFT.6 - Generate Kickout Reports.Programmable (Trigger) Listener</Listener>
          <Synchronous>false</Synchronous>
          <Timeout>60</Timeout>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Normalize Space - Performing Doctors">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform-normalize-space-perf-drs.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
</Route>

