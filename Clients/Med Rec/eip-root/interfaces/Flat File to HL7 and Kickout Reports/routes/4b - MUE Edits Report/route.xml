      <ModuleConfig>
        <TargetDirectory>$$REPORT_TARGET_DIRECTORY</TargetDirectory>
        <FileName>{ognl:getAttribute('com.pilotfish.FileName') + '_' + getAttribute('SplitCode') + '_' + 'MUE_Edits_Accounts_Report_' + new java.text.SimpleDateFormat('MMddyyyy').format(new java.util.Date()) }</FileName>
        <FileExtension>xls</FileExtension>
        <UseFullFilePath>Disabled</UseFullFilePath>
        <FullPathToFile />
        <AppendToFile>false</AppendToFile>
        <MAXIMUM_MEMORY_SIZE>-1</MAXIMUM_MEMORY_SIZE>
        <FileNameConflictPattern />
        <BatchSensitive>false</BatchSensitive>
        <Command />
        <Shell>/bin/bash</Shell>
      </ModuleConfig>
    </Transport>
  </Target>
  <Target icon="" name="XML">
    <FormatProfile name="Relay (System Format)" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.file.DirectoryTransport" name="Flat File to HL7 and Kickout Reports.4b - MUE Edits Report.Directory / File Transport" retries="1">
