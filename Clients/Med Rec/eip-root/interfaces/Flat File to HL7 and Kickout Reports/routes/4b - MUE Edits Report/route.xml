      <Processor class="com.pilotfish.eip.modules.transform.XMLFormattingProcessor" name="Flat File to HL7 and Kickout Reports.4b - MUE Edits Report.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
