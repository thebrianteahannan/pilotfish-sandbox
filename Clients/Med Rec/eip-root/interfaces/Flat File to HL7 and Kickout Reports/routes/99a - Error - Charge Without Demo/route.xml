      <ModuleConfig>
        <TargetDirectory>$$HL7_TARGET_DIRECTORY</TargetDirectory>
        <FileName>{ognl:getAttribute('com.pilotfish.FileName') + '_' + 'Error_ChargeWithoutDemo'}</FileName>
        <FileExtension>txt</FileExtension>
        <UseFullFilePath>Disabled</UseFullFilePath>
        <FullPathToFile />
        <AppendToFile>Create New</AppendToFile>
        <MAXIMUM_MEMORY_SIZE>-1</MAXIMUM_MEMORY_SIZE>
        <FileNameConflictPattern />
        <BatchSensitive>false</BatchSensitive>
        <Command />
        <Shell>/bin/bash</Shell>
      </ModuleConfig>
    </Transport>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.other.TransactionDataPopulationProcessor" name="Flat File to HL7 and Kickout Reports.99a - Error - Charge Without Demo.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <Contents>{ognl:'This file has charges without a demographic associated with it. Please check the file or try to re-run it because something went wrong.'}</Contents>
          <InputType>Text</InputType>
          <Encoding>UTF-8</Encoding>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
</Route>

