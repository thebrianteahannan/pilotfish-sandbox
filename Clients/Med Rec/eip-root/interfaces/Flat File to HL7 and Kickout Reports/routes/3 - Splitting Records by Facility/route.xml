      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Swap Query Info Results Into Data - SPG ONLY">
        <ModuleConfig>
          <ExecuteProcessor>{ognl:getAttribute('Client') == 'SPG'}</ExecuteProcessor>
