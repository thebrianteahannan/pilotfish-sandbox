          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Save Data into Temp Trans Attr For Reports">
