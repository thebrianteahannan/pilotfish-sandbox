          <ExecuteProcessor>false</ExecuteProcessor>
          <Namespace />
          <Tags>[eip_pair:query_results:eip_name:feed_info_query_results:eip_value][eip_pair:import:eip_name:tempData:eip_value]</Tags>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Swap orig data back - PPS ONLY - ALL NOW">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>tempData</AttributeName>
          <SAVEOUTTAG>true</SAVEOUTTAG>
          <SAVEINTAG>false</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
