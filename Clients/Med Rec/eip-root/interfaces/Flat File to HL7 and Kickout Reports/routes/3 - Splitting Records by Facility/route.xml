          <XSLTPath>transform-remove-dups-part1.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Group Splits and Clients Together">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transformGroupSplitsAndClients.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.other.XPathEvaluatorProcessor" name="Get Split Count">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeScope>Transaction</AttributeScope>
          <XPathExpressions>[eip_pair:SplitCount:eip_name:count(//Split[Client/@client_code != '']):eip_value]</XPathExpressions>
          <GlobalAttributeExpressions />
          <Namespaces>null</Namespaces>
          <Namespace />
          <XPath1Compatibility>false</XPath1Compatibility>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.TransactionAttributePopulationProcessor" name="Get Split Count - NPS ONLY">
        <ModuleConfig>
          <ExecuteProcessor>{ognl:getAttribute('Partition') == 'NPS'}</ExecuteProcessor>
          <AttributePairs>[eip_pair:SplitCount:eip_name:{ognl:getAttribute('SplitCount') != null ? (getAttribute('SplitCount') - 1) : 0}:eip_value]</AttributePairs>
          <AttributeScope>Transaction</AttributeScope>
          <GlobalAttributes>BUCKET</GlobalAttributes>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Save Data Again">
        <ModuleConfig>
          <ExecuteProcessor>{ognl:getAttribute('Client') != 'PPA'}</ExecuteProcessor>
          <AttributeName>dataBeforeSplit</AttributeName>
