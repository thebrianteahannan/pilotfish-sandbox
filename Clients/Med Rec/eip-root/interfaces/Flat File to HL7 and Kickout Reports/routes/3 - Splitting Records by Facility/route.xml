          <StoreAsStream>true</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.CallRouteProcessor" name="Generate Kickout Reports (only once before splitting)">
