          <ExecuteProcessor>false</ExecuteProcessor>
          <XSLTPath>transform-PPA-remove-defaults-if-split-present.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Remove Duplicates - Specific Ones">
