          <XSLTParameters>[eip_pair:Tag1:eip_name:query_results:eip_value][eip_pair:Source1:eip_name:feed_info_query_results:eip_value]</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="New Architecture.2-1 - Split Records by Facility.Processor2">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform5.xslt</XSLTPath>
