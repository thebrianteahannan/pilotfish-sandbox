          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>[eip_pair:Partition:eip_name:{ognl:getAttribute('Partition').toUpperCase()}:eip_value][eip_pair:Client:eip_name:{ognl:getAttribute('Client').toUpperCase()}:eip_value]</XSLTParameters>
