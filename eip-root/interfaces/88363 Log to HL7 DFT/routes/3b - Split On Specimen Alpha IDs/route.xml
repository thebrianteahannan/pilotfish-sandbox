<?xml version="1.0" encoding="UTF-8"?>
<Route xmlns="http://www.pilotfishtechnology.com/eipr/RouteSpec" CreatedBy="bthannan@pilotfishtechnology.com" RouteSpecificPooling="true" debugTraceCurrentSecondsToKeepFiles="-1" debugTraceMaxFiles="-1" debuggingTrace="false" debuggingTraceExpression="" debuggingTracePath="" transactionTimeToLive="300000">
  <RouteMetadata />
  <RoutingModule class="com.pilotfish.eip.modules.internal.NullRoutingModule" />
  <TransactionMonitors>
    <TransactionMonitor class="com.pilotfish.eip.modules.internal.RouteTriggerMonitor" name="88363 Log to HL7 DFT.3 - Determine If Splitting Or Not.Transaction Monitor-Copy-1">
      <ModuleConfig>
        <ErrorListenerName>88363 Log to HL7 DFT.99 - Error Handling.Programmable (Trigger) Listener</ErrorListenerName>
        <IncludeData>true</IncludeData>
        <IncludeAttributes>true</IncludeAttributes>
        <SetDataAsMessage>false</SetDataAsMessage>
        <ExceptionClassName />
        <ExceptionMessageLevel>-1</ExceptionMessageLevel>
        <MustContainString />
        <MustNotContainString />
        <IncludeStages />
      </ModuleConfig>
    </TransactionMonitor>
  </TransactionMonitors>
  <Source icon="" name="System Unnamed">
    <FormatProfile name="Fork On Splits" />
    <SourceMetadata />
    <Listener class="com.pilotfish.eip.modules.core.TriggerableListener" enabled="true" name="88363 Log to HL7 DFT.2a - Split On Specimen Alpha IDs.Programmable (Trigger) Listener">
      <ModuleConfig>
        <IS_TRIGGERABLE_LISTENER>false</IS_TRIGGERABLE_LISTENER>
        <CLIAllowed>false</CLIAllowed>
        <RESTART_ON_ERROR_TAG>false</RESTART_ON_ERROR_TAG>
        <FIFOQueueName />
        <FIFOQueueDelay>500</FIFOQueueDelay>
        <TransactionLoggingAllowed>false</TransactionLoggingAllowed>
        <TransactionLoggingStoreData>false</TransactionLoggingStoreData>
        <TransactionLoggingStoreDataBase64>false</TransactionLoggingStoreDataBase64>
        <TransactionLoggingStoreAttributes>false</TransactionLoggingStoreAttributes>
        <TransactionLoggingLogAllAttributes>false</TransactionLoggingLogAllAttributes>
        <TransactionLoggingAllowedLoggedAttributes>[eip_pair:Transaction Resubmit Attribute:eip_name:com.pilotfish.Dashboard.ResubmissionOriginalTxID:eip_value]</TransactionLoggingAllowedLoggedAttributes>
        <CheckInactivity>false</CheckInactivity>
        <InactivityTransactionCount>1</InactivityTransactionCount>
        <InactivityPolling>500</InactivityPolling>
        <MonitoringTime>21:54-21:54</MonitoringTime>
        <InactivityExcludedDays />
        <InactivityIncludeErrors>false</InactivityIncludeErrors>
        <ThrottlingMode>None</ThrottlingMode>
        <ThrottlingMechanism>Blocking</ThrottlingMechanism>
        <ThrottlingConcurrentMessages>1</ThrottlingConcurrentMessages>
        <ThrottlingTimedInterval>1</ThrottlingTimedInterval>
        <ThrottlingSynchronousTimeout>60</ThrottlingSynchronousTimeout>
        <CallingRoutes />
      </ModuleConfig>
    </Listener>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Save Orig Data">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>theData</AttributeName>
          <SAVEOUTTAG>false</SAVEOUTTAG>
          <SAVEINTAG>true</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.db.DatabaseSqlProcessor" name="Get Split Codes List From DB">
        <ModuleConfig>
          <InputFile />
          <WriteQuery>true</WriteQuery>
          <Query>select * from client_codes_spec_alpha_88363</Query>
          <QueryParams />
          <UserName>$$DATABASE_USERNAME</UserName>
          <Password>$$DATABASE_PASSWORD</Password>
          <UseDataSource>false</UseDataSource>
          <DataSource />
          <JdbcDriver>$$DATABASE_DRIVER</JdbcDriver>
          <JdbcURL>$$DATABASE_URL</JdbcURL>
          <KeepConnection>false</KeepConnection>
          <Autocommit>false</Autocommit>
          <EnableTimeout>false</EnableTimeout>
          <Timeout>600</Timeout>
          <RestrictMetaDataToCatalog />
          <RestrictMetaDataToSchema />
          <RestrictMetaDataToTable>%</RestrictMetaDataToTable>
          <CallbackListenerName />
          <UseSingleOutputStream>false</UseSingleOutputStream>
          <ErrorOnUnknownElement>false</ErrorOnUnknownElement>
          <UseJdbcGeneratedKeys>true</UseJdbcGeneratedKeys>
          <JDBCProperties>null</JDBCProperties>
          <UseConnectionPooling>false</UseConnectionPooling>
          <PermittedDBConnections>5</PermittedDBConnections>
          <LogMetadata>false</LogMetadata>
          <LogSQL>false</LogSQL>
          <UseJdbcTyping>false</UseJdbcTyping>
          <TransactionIsolationLevel>Default</TransactionIsolationLevel>
          <TransactionIsolationDriverSpecific>-1</TransactionIsolationDriverSpecific>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Convert DB Results XML to SplitList XML">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform-convert-db-results-to-splitlist-xml.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Save SplitCodesXML to Trans Attr">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>SplitListXML</AttributeName>
          <SAVEOUTTAG>false</SAVEOUTTAG>
          <SAVEINTAG>true</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Swap Orig Data Back In">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>theData</AttributeName>
          <SAVEOUTTAG>true</SAVEOUTTAG>
          <SAVEINTAG>false</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Assign Split Names To Records By Specimen Alpha IDs">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>[eip_pair:SplitListXML:eip_name:{ognl:getAttribute('SplitListXML')}:eip_value]</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Group Records By Split Names">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform-group-by-split-name.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.TransactionAttributePopulationProcessor" name="Set SpecAlphaSplit Boolean">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributePairs>[eip_pair:IsSpecAlphaSplit:eip_name:true:eip_value]</AttributePairs>
          <AttributeScope>Transaction</AttributeScope>
          <GlobalAttributes>BUCKET</GlobalAttributes>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Source>
  <Target icon="" name="System Unnamed">
    <FormatProfile name="Relay (System Format)" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.internal.EIPTransport" name="88363 Log to HL7 DFT.2a - Split On Specimen Alpha IDs.Route to Route Transport" retries="1">
      <ModuleConfig>
        <ServiceName>88363 Log to HL7 DFT.3 - Generate DFT.Programmable (Trigger) Listener</ServiceName>
        <CallbackListenerName />
        <Timeout>60</Timeout>
      </ModuleConfig>
    </Transport>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.other.XPathEvaluatorProcessor" name="88363 Log to HL7 DFT.4 - Split On Specimen Alpha IDs.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeScope>Transaction</AttributeScope>
          <XPathExpressions>[eip_pair:SplitName:eip_name://Split/@name:eip_value][eip_pair:SplitShortName:eip_name://Split/@shortname:eip_value][eip_pair:SplitPrefix:eip_name://Split/@prefix:eip_value]</XPathExpressions>
          <GlobalAttributeExpressions />
          <Namespaces>null</Namespaces>
          <Namespace />
          <XPath1Compatibility>false</XPath1Compatibility>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
</Route>

