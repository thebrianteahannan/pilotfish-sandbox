    <Processors>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Flat File to HL7 and Kickout Reports.3c - Generate HL7 Debug Logging - DFT.Processor3">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>orig_data</AttributeName>
          <SAVEOUTTAG>false</SAVEOUTTAG>
          <SAVEINTAG>true</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.file.StaticFileProcessor" name="Get AccountNumber From File">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <FileName>C:\PilotFish\input\filter_by_account_number.txt</FileName>
          <PostProcessOperation>Do Nothing</PostProcessOperation>
          <TargetDirectory />
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Flat File to HL7 and Kickout Reports.3c - Generate HL7 Debug Logging - DFT.Processor1">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>account_number</AttributeName>
          <SAVEOUTTAG>false</SAVEOUTTAG>
          <SAVEINTAG>true</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.internal.SaveDataToAttributeProcessor" name="Flat File to HL7 and Kickout Reports.3c - Generate HL7 Debug Logging - DFT.Processor4">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <AttributeName>orig_data</AttributeName>
          <SAVEOUTTAG>true</SAVEOUTTAG>
          <SAVEINTAG>false</SAVEINTAG>
          <USEDOCUMENTOBJECTMODEL>false</USEDOCUMENTOBJECTMODEL>
          <StoreAsStream>false</StoreAsStream>
          <IsGlobalAttribute>false</IsGlobalAttribute>
          <GlobalAttributeBucket>DEFAULT</GlobalAttributeBucket>
        </ModuleConfig>
      </Processor>
