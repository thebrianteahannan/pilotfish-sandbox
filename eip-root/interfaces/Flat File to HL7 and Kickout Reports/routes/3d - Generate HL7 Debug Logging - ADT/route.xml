  </Source>
  <Target icon="" name="Write XML">
    <FormatProfile name="Filter Records by AccountNo" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.file.DirectoryTransport" name="Flat File to HL7 and Kickout Reports.3d - Generate HL7 Debug Logging - ADT.Directory / File Transport" retries="1">
      <ModuleConfig>
        <TargetDirectory>{ognl:#properties.get('HL7_TARGET_DIRECTORY') + ( #properties.get('is_debug') ?  @java.io.File@separatorChar + getAttribute('SplitCode') + new java.text.SimpleDateFormat('hhmm').format(new java.util.Date()) : '' )}</TargetDirectory>
        <FileName>{ognl:getAttribute('SplitCode').toString().toUpperCase() + new java.text.SimpleDateFormat('MMdd').format(new java.util.Date()) + 'a_filtered'}</FileName>
        <FileExtension>xml</FileExtension>
        <UseFullFilePath>Disabled</UseFullFilePath>
        <FullPathToFile />
        <AppendToFile>Overwrite</AppendToFile>
        <MAXIMUM_MEMORY_SIZE>-1</MAXIMUM_MEMORY_SIZE>
        <FileNameConflictPattern />
        <BatchSensitive>false</BatchSensitive>
        <Command />
        <Shell>/bin/bash</Shell>
      </ModuleConfig>
    </Transport>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.transform.XMLFormattingProcessor" name="Flat File to HL7 and Kickout Reports.3c - Generate HL7 Debug Logging - DFT.Processor">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
  <Target icon="" name="Write HL7">
    <FormatProfile name="Filter Records by AccountNo" />
    <TargetMetadata />
    <Transport class="com.pilotfish.eip.modules.file.DirectoryTransport" name="Flat File to HL7 and Kickout Reports.3d - Generate HL7 Debug Logging - ADT.Directory / File Transport1" retries="1">
      <ModuleConfig>
        <TargetDirectory>{ognl:#properties.get('HL7_TARGET_DIRECTORY') + ( #properties.get('is_debug') ?  @java.io.File@separatorChar + getAttribute('SplitCode') + new java.text.SimpleDateFormat('hhmm').format(new java.util.Date()) : '' )}</TargetDirectory>
        <FileName>{ognl:getAttribute('SplitCode').toString().toUpperCase() + new java.text.SimpleDateFormat('MMdd').format(new java.util.Date()) + 'a_filtered'}</FileName>
        <FileExtension>ADT</FileExtension>
        <UseFullFilePath>Disabled</UseFullFilePath>
        <FullPathToFile />
        <AppendToFile>Overwrite</AppendToFile>
        <MAXIMUM_MEMORY_SIZE>-1</MAXIMUM_MEMORY_SIZE>
        <FileNameConflictPattern />
        <BatchSensitive>false</BatchSensitive>
        <Command />
        <Shell>/bin/bash</Shell>
      </ModuleConfig>
    </Transport>
    <Processors>
      <Processor class="com.pilotfish.eip.modules.transform.XSLTProcessor" name="Remove MUE Edits Log XML-Copy-1">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>remove_mue_edits.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.transform.hl7.HL7TransformationProcessor" name="Flat File to HL7 and Kickout Reports.3b - Generate HL7 Files.Processor2-Copy-1">
        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <TransformationDirection>XML to HL7 2.X</TransformationDirection>
          <ExecuteTransformation>true</ExecuteTransformation>
          <SUBCOMPONETS_CONFIG>Default</SUBCOMPONETS_CONFIG>
          <FIELDS_TO_FORCE_CHILD_POPULATION />
          <FIELDS_TO_AVOID_CHILD_POPULATION />
          <PUT_FIRST_CHILD_TO_ATTRIBUTE>false</PUT_FIRST_CHILD_TO_ATTRIBUTE>
          <REBUILD_FORMAT_FOR_UNEXPECTED_VERSION>false</REBUILD_FORMAT_FOR_UNEXPECTED_VERSION>
          <USE_ALTERNATIVE_CACHE>false</USE_ALTERNATIVE_CACHE>
          <HL7Version>2.5.1</HL7Version>
          <CACHE_SIZE>20</CACHE_SIZE>
          <CACHE_ON_START>true</CACHE_ON_START>
          <FOLDER_WITH_ADDITIONAL_XSD />
          <FAIL_IF_REQUIRED_NOT_FOUND>false</FAIL_IF_REQUIRED_NOT_FOUND>
          <DETECT_LINE_SEPARATOR_TAG>false</DETECT_LINE_SEPARATOR_TAG>
          <IGNORE_UNKNOWN_Z_SEGMNENTS>false</IGNORE_UNKNOWN_Z_SEGMNENTS>
          <IGNORE_SEGMNENTS_MAX_OCCURS>true</IGNORE_SEGMNENTS_MAX_OCCURS>
          <INCLUDE_EMPTY_FIELDS>false</INCLUDE_EMPTY_FIELDS>
          <USE_FRIENDLY_NAMES>false</USE_FRIENDLY_NAMES>
          <USE_ATTRIBUTE_FRIENDLY_NAMES>false</USE_ATTRIBUTE_FRIENDLY_NAMES>
          <USE_NAMESPACE>false</USE_NAMESPACE>
          <CustomMessageStructure />
          <USE_COMPATIBILITY_SCHEMAS>false</USE_COMPATIBILITY_SCHEMAS>
          <FILL_FORMAT_FIELDS>false</FILL_FORMAT_FIELDS>
          <ADD_BATCH_SEGMENTS>false</ADD_BATCH_SEGMENTS>
        </ModuleConfig>
      </Processor>
    </Processors>
  </Target>
