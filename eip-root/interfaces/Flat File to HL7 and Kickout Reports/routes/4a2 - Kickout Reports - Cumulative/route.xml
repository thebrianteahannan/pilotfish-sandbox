        <ModuleConfig>
          <ExecuteProcessor>true</ExecuteProcessor>
          <XSLTPath>transform-remove-query-results.xslt</XSLTPath>
          <CacheXSLTToXML>false</CacheXSLTToXML>
          <XSLTEngine>Saxon</XSLTEngine>
          <XSLTParameters>null</XSLTParameters>
          <SaxonConverterHandling>Throw Exception</SaxonConverterHandling>
          <SaxonConverterEncoding>UTF-8</SaxonConverterEncoding>
        </ModuleConfig>
      </Processor>
      <Processor class="com.pilotfish.eip.modules.file.FileWriteProcessor" name="Write DB Lookup XML to Disk-Copy-45">
        <ModuleConfig>
          <ExecuteProcessor>{ognl:#properties.get('is_debug')}</ExecuteProcessor>
          <TargetDirectory>$$REPORT_TARGET_DIRECTORY</TargetDirectory>
          <TargetFileName>{ognl:getAttribute('com.pilotfish.FileName') + '_' + 'BeforeRefLocationReport_' + new java.text.SimpleDateFormat('MMddyyyy').format(new java.util.Date()) + '.xml'}</TargetFileName>
        </ModuleConfig>
      </Processor>
    </Processors>
